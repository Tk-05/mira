module main;

import module "./Debug2.mira" as test;

var list : {1,2,4};

fn main() {
    var wrapper : {
        var a : 0;
        var b: 0;
    };

    print($wrapper.a "\n");

    overwrite(
        "fn print(arg) {
            ret(69);
        }"
    );
    
    for(var i in <0..length($list)>) {
        print($i "\n");
    }

    foreach(var i in <0..5>) {
        print($i "\n");
    }

    print(test.hello("test"));
}