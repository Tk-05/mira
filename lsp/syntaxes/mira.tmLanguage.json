{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Mira",
  "scopeName": "source.mira",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords-control" },
    { "include": "#keywords-declaration" },
    { "include": "#keywords-operator" },
    { "include": "#constants-language" },
    { "include": "#constants-numeric" },
    { "include": "#function-definition" },
    { "include": "#variable-reference" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.mira",
          "begin": "/\\*",
          "end": "\\*/"
        },
        {
          "name": "comment.line.double-slash.mira",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.mira",
          "begin": "\"\"\"",
          "end": "\"\"\""
        },
        {
          "name": "string.quoted.double.mira",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.mira",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "keywords-control": {
      "name": "keyword.control.mira",
      "match": "\\b(if|else|while|for|foreach|in|switch|case|default|break|continue|return|try|catch|finally|throw|do)\\b"
    },
    "keywords-declaration": {
      "name": "keyword.declaration.mira",
      "match": "\\b(fn|var|const|async|module|import|enum|native|as)\\b"
    },
    "keywords-operator": {
      "name": "keyword.operator.word.mira",
      "match": "\\b(typeof|await|spawn|eval|assert|length|scan|print|println|httpGet|now|dateFormat|replace|jsonNested|jsonIndexOf)\\b"
    },
    "constants-language": {
      "name": "constant.language.mira",
      "match": "\\b(true|false|null)\\b"
    },
    "constants-numeric": {
      "patterns": [
        {
          "name": "constant.numeric.hex.mira",
          "match": "0[xX][0-9a-fA-F]+"
        },
        {
          "name": "constant.numeric.mira",
          "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
        }
      ]
    },
    "function-definition": {
      "patterns": [
        {
          "name": "entity.name.function.mira",
          "match": "(?<=\\bfn\\s{1,20})([a-zA-Z_][a-zA-Z0-9_]*)"
        }
      ]
    },
    "variable-reference": {
      "name": "variable.other.mira",
      "match": "\\$[a-zA-Z_][a-zA-Z0-9_]*"
    },
    "operators": {
      "name": "keyword.operator.mira",
      "match": "->|\\?\\?|\\|>|:|==|!=|<=|>=|<|>|\\+|-|\\*\\*|\\*|/|%|\\^|&(?!&)|\\|(?!\\|)|\\+\\+|--|\\+=|-=|\\*=|/=|%=|\\*\\*=|&&|\\|\\|"
    }
  }
}
